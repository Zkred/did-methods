{
  "name": "@zkred/did-core",
  "version": "0.1.0",
  "description": "Shared types and utilities for @zkred DID method implementations",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zkred/did-methods.git",
    "directory": "packages/did-core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "did",
    "decentralized-identifiers",
    "ssi"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  }
}